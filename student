entry_program.grid(row=1, column=1, padx=5)

tk.Label(frame_form, text="Year", bg="#f4f6f7").grid(row=1, column=2, padx=5)
entry_year = ttk.Entry(frame_form)
entry_year.grid(row=1, column=3, padx=5)

# ---------- Buttons ----------
ttk.Button(frame_buttons, text="Add", command=add_student).grid(row=0, column=0, padx=10)
ttk.Button(frame_buttons, text="Search", command=search_student).grid(row=0, column=1, padx=10)
ttk.Button(frame_buttons, text="Update", command=update_student).grid(row=0, column=2, padx=10)
ttk.Button(frame_buttons, text="Delete", command=delete_student).grid(row=0, column=3, padx=10)
ttk.Button(frame_buttons, text="Undo", command=undo_delete).grid(row=0, column=4, padx=10)
