# ---------- Table ----------
columns = ("ID", "Name", "Program", "Year")
tree = ttk.Treeview(frame_table, columns=columns, show="headings", height=10)

for col in columns:
    tree.heading(col, text=col)
    tree.column(col, width=150)

tree.pack()

tree.bind("<<TreeviewSelect>>", on_row_select)

# ---------- Run ----------
root.mainloop()